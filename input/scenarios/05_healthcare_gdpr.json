{
    "scenario_name": "05_healthcare_gdpr",
    "description": "Compliance GDPR/HIPAA scenario. An enterprise network with a mix of web, application, database, storage, and monitoring servers. The web servers (web1 and web2) run HTTP and HTTPS services, the application servers (app1 and app2) run Tomcat and FTP services, the database servers (db_master and db_slave) run MySQL, the storage server runs SMB and NetBIOS, and the monitoring server runs Prometheus. The policy forbids certain ports to be exposed to the internet.",
    "hosts": [
        {
            "id": "patient_portal",
            "services": [
                {
                    "name": "http",
                    "port": 80,
                    "depends_on": [
                        "tomcat"
                    ]
                },
                {
                    "name": "https",
                    "port": 443
                },
                {
                    "name": "ssh"
                }
            ]
        },
        {
            "id": "ehr_app",
            "services": [
                {
                    "name": "tomcat",
                    "port": 8080,
                    "critical": true,
                    "depends_on": [
                        "postgresql"
                    ]
                },
                {
                    "name": "https",
                    "port": 443,
                    "critical": true
                },
                {
                    "name": "ssh"
                }
            ]
        },
        {
            "id": "legacy_gateway",
            "services": [
                {
                    "name": "smtp",
                    "port": 25
                },
                {
                    "name": "telnet",
                    "port": 23
                },
                {
                    "name": "ssh"
                }
            ]
        },
        {
            "id": "patient_db",
            "services": [
                {
                    "name": "postgresql",
                    "critical": true
                },
                {
                    "name": "ssh"
                }
            ]
        },
        {
            "id": "medical_files",
            "services": [
                {
                    "name": "smb",
                    "port": 445
                },
                {
                    "name": "netbios",
                    "port": 139
                },
                {
                    "name": "ssh"
                }
            ]
        },
        {
            "id": "admin_ws",
            "services": [
                {
                    "name": "rdp",
                    "port": 3389
                },
                {
                    "name": "snmp",
                    "port": 161
                },
                {
                    "name": "ssh"
                }
            ]
        },
        {
            "id": "audit_db",
            "services": [
                {
                    "name": "mysql",
                    "critical": true
                },
                {
                    "name": "netbios",
                    "port": 139
                },
                {
                    "name": "ssh"
                }
            ]
        }
    ],
    "policy": {
        "forbidden_ports": [
            80,
            25,
            23,
            139,
            161,
            3389
        ]
    }
}