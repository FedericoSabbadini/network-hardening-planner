{
    "scenario_name": "04_security_incident",
    "description": "Post-breach hardening",
    "hosts": [
        {
            "id": "dmz_web",
            "services": [
                {
                    "name": "http",
                    "port": 80,
                    "depends_on": [
                        "tomcat"
                    ]
                },
                {
                    "name": "https",
                    "port": 443
                },
                {
                    "name": "ssh"
                }
            ]
        },
        {
            "id": "dmz_mail",
            "services": [
                {
                    "name": "smtp",
                    "port": 25
                },
                {
                    "name": "pop3",
                    "port": 110
                },
                {
                    "name": "imap",
                    "port": 143
                },
                {
                    "name": "ssh"
                }
            ]
        },
        {
            "id": "internal_app",
            "services": [
                {
                    "name": "tomcat",
                    "port": 8080,
                    "depends_on": [
                        "mysql"
                    ]
                },
                {
                    "name": "rdp",
                    "port": 3389
                },
                {
                    "name": "ssh"
                }
            ]
        },
        {
            "id": "admin_jump",
            "services": [
                {
                    "name": "vnc",
                    "port": 5900
                },
                {
                    "name": "tftp",
                    "port": 69
                },
                {
                    "name": "ssh"
                }
            ]
        },
        {
            "id": "legacy_server",
            "services": [
                {
                    "name": "telnet",
                    "port": 23
                },
                {
                    "name": "netbios",
                    "port": 139
                },
                {
                    "name": "ssh"
                }
            ]
        },
        {
            "id": "db_primary",
            "services": [
                {
                    "name": "mysql",
                    "critical": true
                },
                {
                    "name": "ssh"
                }
            ]
        }
    ],
    "policy": {
        "forbidden_ports": [
            80,
            25,
            23,
            139,
            3389,
            5900,
            69
        ]
    }
}