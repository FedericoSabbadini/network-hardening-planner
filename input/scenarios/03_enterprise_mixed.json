{
    "scenario_name": "03_enterprise_mixed",
    "description": "An enterprise network with a mix of web, application, database, storage, and monitoring servers. The web servers (web1 and web2) run HTTP and HTTPS services, the application servers (app1 and app2) run Tomcat and FTP services, the database servers (db_master and db_slave) run MySQL, the storage server runs SMB and NetBIOS, and the monitoring server runs Prometheus. The policy forbids certain ports to be exposed to the internet.",
    "hosts": [
        {
            "id": "web1",
            "features": [
                {
                    "name": "http",
                    "port": 80,
                    "depends_on": [
                        "tomcat"
                    ]
                },
                {
                    "name": "https",
                    "port": 443
                },
                {
                    "name": "ssh",
                    "port": 22
                }
            ]
        },
        {
            "id": "web2",
            "features": [
                {
                    "name": "http",
                    "port": 80,
                    "depends_on": [
                        "tomcat"
                    ]
                },
                {
                    "name": "https",
                    "port": 443
                },
                {
                    "name": "ssh",
                    "port": 22
                }
            ]
        },
        {
            "id": "app1",
            "features": [
                {
                    "name": "tomcat",
                    "port": 8080,
                    "depends_on": [
                        "mysql"
                    ]
                },
                {
                    "name": "ftp",
                    "port": 21
                },
                {
                    "name": "snmp",
                    "port": 161
                },
                {
                    "name": "ssh",
                    "port": 22
                }
            ]
        },
        {
            "id": "app2",
            "features": [
                {
                    "name": "tomcat",
                    "port": 8080,
                    "depends_on": [
                        "mysql"
                    ]
                },
                {
                    "name": "ftp",
                    "port": 21
                },
                {
                    "name": "ssh",
                    "port": 22
                }
            ]
        },
        {
            "id": "db_master",
            "features": [
                {
                    "service": "mysql",
                    "port": 3306,
                    "critical": true
                },
                {
                    "service": "ssh",
                    "port": 22
                }
            ]
        },
        {
            "id": "db_slave",
            "features": [
                {
                    "service": "mysql",
                    "port": 3306,
                    "critical": true
                },
                {
                    "service": "ssh",
                    "port": 22
                }
            ]
        },
        {
            "id": "storage",
            "features": [
                {
                    "service": "smb",
                    "port": 445
                },
                {
                    "service": "netbios",
                    "port": 139
                },
                {
                    "service": "ssh",
                    "port": 22
                }
            ]
        },
        {
            "id": "monitoring",
            "features": [
                {
                    "service": "prometheus",
                    "port": 9090
                },
                {
                    "service": "ssh",
                    "port": 22
                },
                {
                    "service": "telnet",
                    "port": 23
                }
            ]
        }
    ],
    "policy": {
        "forbidden_ports": [
            80,
            21,
            23,
            139,
            161
        ]
    }
}