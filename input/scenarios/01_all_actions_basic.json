{
    "scenario_name": "01_all_actions_basic",
    "description": "A basic scenario with three hosts, each with a mix of open ports and services. The policy forbids certain ports, and there are no critical services defined.",
    "hosts": [
        {
            "id": "web1",
            "features": [
                {
                    "service": "http",
                    "port": 80
                },
                {
                    "service": "https",
                    "port": 443
                },
                {
                    "service": "ssh",
                    "port": 22
                }
            ]
        },
        {
            "id": "fileserver",
            "features": [
                {
                    "service": "netbios",
                    "port": 139
                },
                {
                    "service": "smb",
                    "vulnerable": true,
                    "port": 445
                },
                {
                    "service": "ssh",
                    "port": 22
                }
            ]
        },
        {
            "id": "legacy",
            "features": [
                {
                    "service": "ssh",
                    "port": 22
                },
                {
                    "service": "telnet",
                    "port": 23
                }
            ]
        }
    ],
    "policy": {
        "forbidden_ports": [
            80,
            139,
            23
        ],
        "forbidden_services": []
    }
}