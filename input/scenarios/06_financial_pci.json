{
    "scenario_name": "06_financial_pci",
    "description": "Compliance PCI-DSS scenario. An enterprise network with a mix of web, application, database, storage, and monitoring servers.",
    "hosts": [
        {
            "id": "web_banking",
            "features": [
                {
                    "service": "http",
                    "port": 80,
                    "depends_on_service": [
                        {
                            "host": "api_gateway",
                            "service": "nodejs"
                        }
                    ]
                },
                {
                    "service": "https",
                    "port": 443
                },
                {
                    "service": "ssh",
                    "port": 22
                }
            ]
        },
        {
            "id": "api_gateway",
            "features": [
                {
                    "service": "https",
                    "port": 443
                },
                {
                    "service": "nodejs",
                    "port": 3000,
                    "depends_on_service": [
                        {
                            "host": "core_banking",
                            "service": "tomcat"
                        },
                        {
                            "host": "mq_cluster",
                            "service": "rabbitmq"
                        }
                    ]
                },
                {
                    "service": "ssh",
                    "port": 22
                }
            ]
        },
        {
            "id": "core_banking",
            "features": [
                {
                    "service": "tomcat",
                    "port": 8080,
                    "critical": true
                },
                {
                    "service": "tftp",
                    "port": 69
                },
                {
                    "service": "ssh",
                    "port": 22
                }
            ]
        },
        {
            "id": "tx_processor",
            "features": [
                {
                    "service": "tomcat",
                    "port": 8080,
                    "critical": true,
                    "depends_on_service": [
                        {
                            "host": "accounts_db",
                            "service": "postgresql"
                        },
                        {
                            "host": "mq_cluster",
                            "service": "rabbitmq"
                        }
                    ]
                },
                {
                    "service": "https",
                    "port": 443,
                    "critical": true
                },
                {
                    "service": "ssh",
                    "port": 22
                }
            ]
        },
        {
            "id": "mq_cluster",
            "features": [
                {
                    "service": "rabbitmq",
                    "port": 5672
                },
                {
                    "service": "snmp",
                    "port": 161
                },
                {
                    "service": "ssh",
                    "port": 22
                }
            ]
        },
        {
            "id": "accounts_db",
            "features": [
                {
                    "service": "postgresql",
                    "port": 5432,
                    "critical": true
                },
                {
                    "service": "telnet",
                    "port": 23
                },
                {
                    "service": "ssh",
                    "port": 22
                }
            ]
        },
        {
            "id": "tx_db",
            "features": [
                {
                    "service": "postgresql",
                    "port": 5432,
                    "critical": true
                },
                {
                    "service": "netbios",
                    "port": 139
                },
                {
                    "service": "ssh",
                    "port": 22
                }
            ]
        },
        {
            "id": "admin_console",
            "features": [
                {
                    "service": "rdp",
                    "port": 3389
                },
                {
                    "service": "vnc",
                    "port": 5900
                },
                {
                    "service": "ssh",
                    "port": 22
                }
            ]
        },
        {
            "id": "security_siem",
            "features": [
                {
                    "service": "elasticsearch",
                    "port": 9200
                },
                {
                    "service": "kibana",
                    "port": 5601,
                    "vulnerable": true
                },
                {
                    "service": "ssh",
                    "port": 22
                },
                {
                    "service": "telnet",
                    "port": 23
                }
            ]
        }
    ],
    "policy": {
        "forbidden_ports": [
            80,
            23,
            139,
            161,
            69,
            3389,
            5900
        ],
        "forbidden_services": [
            "ftp",
            "telnet",
            "tftp",
            "snmp"
        ]
    }
}