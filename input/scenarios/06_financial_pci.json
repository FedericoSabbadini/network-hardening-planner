{
    "scenario_name": "06_financial_pci",
    "description": "Compliance PCI-DSS scenario. An enterprise network with a mix of web, application, database, storage, and monitoring servers. The web servers (web1 and web2) run HTTP and HTTPS services, the application servers (app1 and app2) run Tomcat and FTP services, the database servers (db_master and db_slave) run MySQL, the storage server runs SMB and NetBIOS, and the monitoring server runs Prometheus. The policy forbids certain ports to be exposed to the internet.",
    "hosts": [
        {
            "id": "web_banking",
            "features": [
                {
                    "service": "http",
                    "port": 80,
                    "depends_on": [
                        "nodejs"
                    ]
                },
                {
                    "service": "https",
                    "port": 443
                },
                {
                    "service": "ssh"
                }
            ]
        },
        {
            "id": "api_gateway",
            "features": [
                {
                    "service": "https",
                    "port": 443
                },
                {
                    "service": "nodejs",
                    "port": 3000,
                    "depends_on": [
                        "tomcat",
                        "rabbitmq"
                    ]
                },
                {
                    "service": "ssh"
                }
            ]
        },
        {
            "id": "core_banking",
            "features": [
                {
                    "service": "tomcat",
                    "port": 8080,
                    "critical": true
                },
                {
                    "service": "tftp",
                    "port": 69
                },
                {
                    "service": "ssh"
                }
            ]
        },
        {
            "id": "tx_processor",
            "features": [
                {
                    "service": "tomcat",
                    "port": 8080,
                    "critical": true,
                    "depends_on": [
                        "postgresql",
                        "rabbitmq"
                    ]
                },
                {
                    "service": "https",
                    "port": 443,
                    "critical": true
                },
                {
                    "service": "ssh"
                }
            ]
        },
        {
            "id": "mq_cluster",
            "features": [
                {
                    "service": "rabbitmq",
                    "port": 5672
                },
                {
                    "service": "snmp",
                    "port": 161
                },
                {
                    "service": "ssh"
                }
            ]
        },
        {
            "id": "accounts_db",
            "features": [
                {
                    "service": "postgresql",
                    "port": 5432,
                    "critical": true
                },
                {
                    "service": "telnet",
                    "port": 23
                },
                {
                    "service": "ssh"
                }
            ]
        },
        {
            "id": "tx_db",
            "features": [
                {
                    "service": "postgresql",
                    "port": 5432,
                    "critical": true
                },
                {
                    "service": "netbios",
                    "port": 139
                },
                {
                    "service": "ssh"
                }
            ]
        },
        {
            "id": "admin_console",
            "features": [
                {
                    "service": "rdp",
                    "port": 3389
                },
                {
                    "service": "vnc",
                    "port": 5900
                },
                {
                    "service": "ssh"
                }
            ]
        },
        {
            "id": "security_siem",
            "features": [
                {
                    "service": "elasticsearch",
                    "port": 9200
                },
                {
                    "service": "kibana",
                    "port": 5601
                },
                {
                    "service": "ssh"
                },
                {
                    "service": "telnet",
                    "port": 23
                }
            ]
        }
    ],
    "policy": {
        "forbidden_ports": [
            80,
            23,
            139,
            161,
            69,
            3389,
            5900
        ]
    }
}