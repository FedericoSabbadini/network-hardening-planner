{
    "scenario_name": "02_deps_all_actions",
    "description": "Scenario with service dependencies and all actions available.",
    "hosts": [
        {
            "id": "frontend",
            "services": [
                {
                    "name": "http",
                    "port": 80,
                    "depends_on": [
                        "tomcat"
                    ]
                },
                {
                    "name": "https",
                    "port": 443
                },
                {
                    "name": "ssh",
                    "port": 22
                }
            ]
        },
        {
            "id": "backend",
            "services": [
                {
                    "name": "tomcat",
                    "port": 8080,
                    "depends_on": [
                        "mysql"
                    ]
                },
                {
                    "name": "ssh",
                    "port": 22
                }
            ]
        },
        {
            "id": "mailserver",
            "services": [
                {
                    "name": "smtp",
                    "port": 25
                },
                {
                    "name": "ssh",
                    "port": 22
                }
            ]
        },
        {
            "id": "database",
            "services": [
                {
                    "name": "mysql",
                    "port": 3306,
                    "critical": true
                },
                {
                    "name": "ssh",
                    "port": 22
                },
                {
                    "name": "telnet",
                    "port": 23
                }
            ]
        }
    ],
    "policy": {
        "forbidden_ports": [
            80,
            25,
            23
        ]
    }
}