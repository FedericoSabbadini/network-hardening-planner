{
    "scenario_name": "02_deps_all_actions",
    "description": "Scenario with service dependencies and all actions available. The policy forbids certain ports and services, and the critical service is mysql on the database host.",
    "hosts": [
        {
            "id": "frontend",
            "features": [
                {
                    "service": "http",
                    "depends_on_service": [
                        {
                            "host": "backend",
                            "service": "tomcat"
                        }
                    ],
                    "port": 80
                },
                {
                    "service": "https",
                    "port": 443
                },
                {
                    "service": "ssh",
                    "port": 22
                }
            ]
        },
        {
            "id": "backend",
            "features": [
                {
                    "service": "tomcat",
                    "depends_on_service": [
                        {
                            "host": "database",
                            "service": "mysql"
                        }
                    ],
                    "port": 8080
                },
                {
                    "service": "ssh",
                    "port": 22
                }
            ]
        },
        {
            "id": "mailserver",
            "features": [
                {
                    "service": "smtp",
                    "port": 25
                },
                {
                    "service": "ssh",
                    "port": 22
                }
            ]
        },
        {
            "id": "database",
            "features": [
                {
                    "service": "mysql",
                    "critical": true,
                    "port": 3306
                },
                {
                    "service": "ssh",
                    "port": 22
                },
                {
                    "service": "telnet",
                    "vulnerable": true,
                    "port": 23
                }
            ]
        }
    ],
    "policy": {
        "forbidden_ports": [
            80,
            25,
            23
        ],
        "forbidden_services": [
            "telnet"
        ]
    }
}